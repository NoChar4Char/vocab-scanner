{
  "manifest_version": 3,
  "name": "Vocab Scanner",
  "version": "1.0.0",
  "description": "Scan web pages and PDFs for hard vocabulary words. Build your master vocabulary PDF over time.",
  "permissions": ["storage", "unlimitedStorage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["libs/pdf.worker.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
